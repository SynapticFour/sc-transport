FROM rust:1.78-slim AS builder
WORKDIR /build
COPY . .
RUN cargo build --release -p sct-cli
FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates iputils-ping \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/target/release/sct /usr/local/bin/sct
EXPOSE 9410
CMD ["sct", "recv", "--port", "9410", "--output-dir", "/data/", "--daemon"]
